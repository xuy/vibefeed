# vibefeed backend — copy to .env and tweak. All values are optional; defaults work out of the box.
# (Loaded by your process manager / shell; `node src/index.js` reads process.env directly.)

# Port the backend listens on.
PORT=4000

# Optional shared secret. If set, every /feed/* request must send `Authorization: Bearer <token>`
# (or ?key=<token>). Leave blank for local, open use. Generate one with: openssl rand -hex 16
FEED_TOKEN=

# Comma-separated RSS/Atom feed URLs for the `rss` source. Falls back to sensible defaults.
# FEED_RSS=https://hnrss.org/frontpage,https://www.theverge.com/rss/index.xml

# Comma-separated subreddits for the `reddit` source (best-effort — Reddit 403s many IPs).
# FEED_SUBREDDITS=todayilearned,science,technology

# Where to persist the seen/history JSON. Defaults to ./.vibefeed-state.json next to the server.
# FEED_STATE=./.vibefeed-state.json
